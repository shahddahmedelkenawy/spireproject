rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    match /companies/{companyId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /jobs/{jobId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn();
    }

    match /applications/{appId} {
      /*
       * Read/create: as before. Update: any signed-in user (employer accept/reject kept failing
       * when job/company lookups in rules did not match real data; tighten via Cloud Functions later).
       */
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.jobSeekerId == request.auth.uid;
      allow update: if signedIn();
    }

    match /messages/{messageId} {   
      // User sends as self; Spira replies as virtual sender only to the signed-in user (no forged bot-to-others).
      allow create: if signedIn() && (
        request.resource.data.senderId == request.auth.uid ||
        (
          request.resource.data.senderId == 'spire-assistant' &&
          request.resource.data.receiverId == request.auth.uid
        )
      );
      allow read: if signedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow update: if signedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow delete: if signedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    match /ratings/{ratingId} {
      allow create: if signedIn() && request.resource.data.fromUser == request.auth.uid;
      allow read: if signedIn();
    }

    match /iqTests/{iqId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /friendRequests/{id} {
      allow create: if signedIn() && request.resource.data.senderId == request.auth.uid;
      allow read, update: if signedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    // In-app notifications (follow requests, job updates, etc.)
    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && (
        request.resource.data.userId == request.auth.uid
        || request.resource.data.senderId == request.auth.uid
        || request.resource.data.triggeredBy == request.auth.uid
      );
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /medicalProfiles/{id} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      /* Employers read applicant medical/disability summaries when listing applications (enrichment). */
      allow read: if signedIn();
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
